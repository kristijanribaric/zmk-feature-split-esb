menuconfig ZMK_SPLIT_ESB
    bool "ZMK ESB split transport (single peripheral)"
    depends on ZMK_SPLIT
    select ESB
    help
      Enhanced ShockBurst (2.4 GHz) split transport for a single peripheral and a
      single central. One ESB packet carries one complete split message; ESB
      hardware ACK, retransmit and CRC provide reliability.

if ZMK_SPLIT_ESB

config ZMK_SPLIT_ESB_MAX_PAYLOAD
    int "Max on-air payload bytes"
    default 48
    help
      Must be >= the largest split message struct. A build assert checks this.

config ZMK_SPLIT_ESB_RX_QUEUE_SIZE
    int "Received-packet ring depth (power of 2)"
    default 16
    help
      Lock-free SPSC ring between the radio ISR and the dispatch thread. Must be
      a power of 2. Deep enough to ride out dispatch stalls at the RX rate.

config ZMK_SPLIT_ESB_RX_THREAD_STACK_SIZE
    int "RX dispatch thread stack size"
    default 1536
    help
      The dispatch thread runs the role-layer RX callback (split event / command
      handler), so it needs comparable stack to the work it replaced.

config ZMK_SPLIT_ESB_RX_THREAD_PRIORITY
    int "RX dispatch thread priority"
    default 2

config ZMK_SPLIT_ESB_REPLY_QUEUE_SIZE
    int "Central: pending reverse-channel command depth"
    default 8

config ZMK_SPLIT_ESB_TX_FIFO_SIZE
    int "Radio TX FIFO depth"
    default 8

config ZMK_SPLIT_ESB_RX_FIFO_SIZE
    int "Radio RX FIFO depth"
    default 8

config ZMK_SPLIT_ESB_PRIORITY
    int "Split transport registration priority"
    default 50

config ESB_MAX_PAYLOAD_LENGTH
    default ZMK_SPLIT_ESB_MAX_PAYLOAD

config ESB_TX_FIFO_SIZE
    default ZMK_SPLIT_ESB_TX_FIFO_SIZE

config ESB_RX_FIFO_SIZE
    default ZMK_SPLIT_ESB_RX_FIFO_SIZE

module = ZMK_SPLIT_ESB
module-str = ZMK ESB split transport
source "subsys/logging/Kconfig.template.log_config"

endif # ZMK_SPLIT_ESB
